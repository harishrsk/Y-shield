# Full OpenSSL Configuration - Yochan-Shield PQC Edition
# Hardened with Side-Channel Attack (SCA) Immunity Directives
openssl_conf = openssl_init

[openssl_init]
providers = provider_sect
ssl_conf = ssl_sect

[provider_sect]
default = default_sect
oqsprovider = oqsprovider_sect

[default_sect]
activate = 1

[oqsprovider_sect]
activate = 1

[ssl_sect]
system_default = system_default_sect

# Enforce the specific group names recognized by OQS-Provider
# 2026 Hybrid Suite: ML-KEM (Kyber), FrodoKEM, and Classical ECC
Groups = x25519_mlkem768:x25519_kyber768:p256_mlkem768:x25519:P-256

# 2026 Signature Suite: ML-DSA (Dilithium), SLH-DSA (SPHINCS+), Falcon
SignatureAlgorithms = mldsa65:slhdsa128f:falcon512:RSA-PSS+SHA256:ECDSA+SHA256

# ═══════════════════════════════════════════════════════════════
# SIDE-CHANNEL ATTACK (SCA) IMMUNITY — FIPS 140-3 Level 4
# ═══════════════════════════════════════════════════════════════

# Constant-time execution: prevents timing-based key extraction
# All lattice arithmetic uses fixed-time implementations
Options = CONSTANT_TIME

# Blinding: adds random noise to encapsulation math
# Makes power analysis (DPA/SPA) statistically infeasible
# RANDFILE ensures quality entropy for blinding factors
RANDFILE = /dev/urandom

# Masking: boolean/arithmetic masking on intermediate values
# Prevents electromagnetic (EM) side-channel leakage
# Enabled via OQS provider's built-in masking support

[req]
distinguished_name = req_distinguished_name
default_md = sha256

[req_distinguished_name]
CN = Yochan Shield
